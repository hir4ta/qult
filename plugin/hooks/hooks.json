{
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "/bin/sh \"$HOME/.claude/plugins/claude-buddy/bin/run.sh\" hook-handler Notification",
            "timeout": 2,
            "type": "command"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "command": "/bin/sh \"$HOME/.claude/plugins/claude-buddy/bin/run.sh\" hook-handler PermissionRequest",
            "timeout": 1,
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "async": true,
            "command": "/bin/sh \"$HOME/.claude/plugins/claude-buddy/bin/run.sh\" hook-handler PostToolUse",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "command": "/bin/sh \"$HOME/.claude/plugins/claude-buddy/bin/run.sh\" hook-handler PostToolUseFailure",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "/bin/sh \"$HOME/.claude/plugins/claude-buddy/bin/run.sh\" hook-handler PreCompact",
            "timeout": 3,
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "/bin/sh \"$HOME/.claude/plugins/claude-buddy/bin/run.sh\" hook-handler PreToolUse",
            "timeout": 2,
            "type": "command"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "async": true,
            "command": "/bin/sh \"$HOME/.claude/plugins/claude-buddy/bin/run.sh\" hook-handler SessionEnd",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "/bin/sh \"$HOME/.claude/plugins/claude-buddy/bin/run.sh\" hook-handler SessionStart",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "startup|resume|compact"
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "command": "/bin/sh \"$HOME/.claude/plugins/claude-buddy/bin/run.sh\" hook-handler SubagentStart",
            "timeout": 3,
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "command": "/bin/sh \"$HOME/.claude/plugins/claude-buddy/bin/run.sh\" hook-handler SubagentStop",
            "timeout": 3,
            "type": "command"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "command": "/bin/sh \"$HOME/.claude/plugins/claude-buddy/bin/run.sh\" hook-handler TaskCompleted",
            "timeout": 3,
            "type": "command"
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "async": true,
            "command": "/bin/sh \"$HOME/.claude/plugins/claude-buddy/bin/run.sh\" hook-handler TeammateIdle",
            "timeout": 3,
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "/bin/sh \"$HOME/.claude/plugins/claude-buddy/bin/run.sh\" hook-handler UserPromptSubmit",
            "timeout": 2,
            "type": "command"
          }
        ]
      }
    ]
  }
}
