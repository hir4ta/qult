{
  "description": "Proactive hooks — auto-import, memory injection, spec session persistence",
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "alfred hook PreCompact",
            "statusMessage": "alfred: saving session state...",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "alfred hook SessionStart",
            "statusMessage": "alfred: restoring session context...",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "alfred hook UserPromptSubmit",
            "statusMessage": "alfred: searching memories...",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "alfred hook PostToolUse",
            "statusMessage": "alfred: checking context...",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "command": "alfred hook PreToolUse",
            "statusMessage": "alfred: checking spec approval...",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "alfred hook Stop",
            "statusMessage": "alfred: checking completion...",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ]
  }
}
