{
  "description": "Silent butler hooks — CLAUDE.md auto-ingest on session start",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/run.sh\" hook SessionStart",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ]
  }
}
