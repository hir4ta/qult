{
  "description": "Proactive hooks — auto-import, memory injection, spec session persistence",
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/run.sh\" hook PreCompact",
            "statusMessage": "alfred: saving session state...",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/run.sh\" hook SessionStart",
            "statusMessage": "alfred: restoring session context...",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/run.sh\" hook UserPromptSubmit",
            "statusMessage": "alfred: searching memories...",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ]
  }
}
