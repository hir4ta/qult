// =============================================================================
// alfred.kdl — Zellij layout for Claude Code + alfred Butler Protocol
//
// Usage: zellij --layout ~/.config/zellij/layouts/alfred.kdl
//   or:  zellij --layout /path/to/claude-alfred/plugin/layouts/alfred.kdl
//
// Tab 1 "Work":  Terminal (left) + spec/decisions/git (right)
// Tab 2 "Shell": Free terminal for nvim, git, etc.
// =============================================================================

layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:compact-bar"
        }
        children
    }

    tab name="Work" focus=true {
        pane split_direction="vertical" {
            // Left: Main terminal (run claude, claude --continue, etc.)
            pane size="60%" name="main" focus=true
            // Right: 3 monitoring panes (Bubbletea TUI)
            pane size="40%" split_direction="horizontal" {
                // Spec watcher: session.md
                pane size="34%" name="spec" {
                    command "alfred"
                    args "pane" "spec"
                }
                // Decisions
                pane size="33%" name="decisions" {
                    command "alfred"
                    args "pane" "decisions"
                }
                // Git status + diff
                pane size="33%" name="git" {
                    command "alfred"
                    args "pane" "git"
                }
            }
        }
    }

    tab name="Shell" {
        pane name="shell" focus=true
    }
}
