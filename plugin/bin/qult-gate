#!/usr/bin/env bash
# qult-gate — Run quality gates from the command line.
#
# Usage:
#   qult-gate status       Show pending fixes and session state
#   qult-gate run-lint     Run on_write gates on a file
#   qult-gate run-test     Run on_commit gates
#   qult-gate version      Show qult version
#
# This script is added to PATH by the qult plugin.
# It queries ~/.qult/qult.db for gate configuration.

set -euo pipefail

DB_PATH="${HOME}/.qult/qult.db"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
NC='\033[0m'

cmd="${1:-help}"

case "$cmd" in
  status)
    echo -e "${CYAN}qult gate status${NC}"
    if [ ! -f "$DB_PATH" ]; then
      echo -e "${YELLOW}No DB found.${NC} Run /qult:init"
      exit 0
    fi

    # Show gates
    echo -e "\n${CYAN}Gates:${NC}"
    if command -v bun >/dev/null 2>&1; then
      bun -e "
        const { Database } = require('bun:sqlite');
        const db = new Database('$DB_PATH', { readonly: true });
        const cwd = process.cwd();
        const project = db.prepare('SELECT id FROM projects WHERE path = ?').get(cwd);
        if (!project) { console.log('  Project not registered. Run /qult:init'); process.exit(0); }
        const gates = db.prepare('SELECT phase, gate_name, command FROM gate_configs WHERE project_id = ?').all(project.id);
        if (gates.length === 0) { console.log('  No gates configured.'); process.exit(0); }
        for (const g of gates) { console.log('  ' + g.phase + '/' + g.gate_name + ': ' + g.command); }
        db.close();
      "
    else
      echo -e "${YELLOW}Bun required for qult-gate.${NC}"
      exit 1
    fi

    # Show pending fixes
    echo -e "\n${CYAN}State:${NC}"
    bun -e "
      const { Database } = require('bun:sqlite');
      const db = new Database('$DB_PATH', { readonly: true });
      const cwd = process.cwd();
      const project = db.prepare('SELECT id FROM projects WHERE path = ?').get(cwd);
      if (!project) { console.log('  No session data.'); process.exit(0); }
      const session = db.prepare('SELECT id FROM sessions WHERE project_id = ? ORDER BY started_at DESC LIMIT 1').get(project.id);
      if (!session) { console.log('  No active session.'); process.exit(0); }
      const fixes = db.prepare('SELECT count(*) as n FROM pending_fixes WHERE session_id = ?').get(session.id);
      if (fixes.n === 0) { console.log('  Pending fixes: \x1b[32mnone\x1b[0m'); }
      else { console.log('  Pending fixes: \x1b[31m' + fixes.n + '\x1b[0m'); }
      db.close();
    "
    ;;

  run-lint)
    file="${2:-}"
    if [ -z "$file" ]; then
      echo "Usage: qult-gate run-lint <file>"
      exit 1
    fi
    if [ ! -f "$DB_PATH" ]; then
      echo "No DB found. Run /qult:init"
      exit 0
    fi
    echo -e "${CYAN}Running on_write gates on ${file}${NC}"
    bun -e "
      const { Database } = require('bun:sqlite');
      const { execSync } = require('child_process');
      const db = new Database('$DB_PATH', { readonly: true });
      const cwd = process.cwd();
      const project = db.prepare('SELECT id FROM projects WHERE path = ?').get(cwd);
      if (!project) { console.log('Project not registered.'); process.exit(0); }
      const gates = db.prepare(\"SELECT gate_name, command, timeout FROM gate_configs WHERE project_id = ? AND phase = 'on_write'\").all(project.id);
      db.close();
      let ok = true;
      for (const g of gates) {
        const cmd = g.command.replace('{file}', '$file');
        process.stdout.write('  ' + g.gate_name + ': ');
        try {
          execSync(cmd, { stdio: 'pipe', timeout: g.timeout || 10000 });
          console.log('\x1b[32mPASS\x1b[0m');
        } catch (e) {
          console.log('\x1b[31mFAIL\x1b[0m');
          if (e.stderr) process.stderr.write(e.stderr.toString().slice(0, 500));
          ok = false;
        }
      }
      process.exit(ok ? 0 : 1);
    "
    ;;

  run-test)
    if [ ! -f "$DB_PATH" ]; then
      echo "No DB found. Run /qult:init"
      exit 0
    fi
    echo -e "${CYAN}Running on_commit gates${NC}"
    bun -e "
      const { Database } = require('bun:sqlite');
      const { execSync } = require('child_process');
      const db = new Database('$DB_PATH', { readonly: true });
      const cwd = process.cwd();
      const project = db.prepare('SELECT id FROM projects WHERE path = ?').get(cwd);
      if (!project) { console.log('Project not registered.'); process.exit(0); }
      const gates = db.prepare(\"SELECT gate_name, command, timeout FROM gate_configs WHERE project_id = ? AND phase = 'on_commit'\").all(project.id);
      db.close();
      let ok = true;
      for (const g of gates) {
        process.stdout.write('  ' + g.gate_name + ': ');
        try {
          execSync(g.command, { stdio: 'pipe', timeout: g.timeout || 30000 });
          console.log('\x1b[32mPASS\x1b[0m');
        } catch (e) {
          console.log('\x1b[31mFAIL\x1b[0m');
          if (e.stderr) process.stderr.write(e.stderr.toString().slice(0, 500));
          ok = false;
        }
      }
      process.exit(ok ? 0 : 1);
    "
    ;;

  version)
    if [ -f "${CLAUDE_PLUGIN_ROOT:-}/dist/hook.mjs" ]; then
      bun -e "
        const src = require('fs').readFileSync('${CLAUDE_PLUGIN_ROOT}/dist/hook.mjs','utf8');
        const m = src.match(/__QULT_VERSION__.*?\"([^\"]+)\"/);
        console.log('qult ' + (m ? m[1] : 'unknown'));
      " 2>/dev/null || echo "qult (version unknown)"
    else
      echo "qult (plugin root not found)"
    fi
    ;;

  help|*)
    echo "qult-gate — Quality gate CLI (requires Bun)"
    echo ""
    echo "Commands:"
    echo "  status       Show gate config and pending fixes"
    echo "  run-lint <f> Run on_write gates on a file"
    echo "  run-test     Run on_commit gates"
    echo "  version      Show qult version"
    ;;
esac
