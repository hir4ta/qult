{
  "name": "@hir4ta/qult",
  "version": "1.1.1",
  "publishConfig": {
    "access": "public"
  },
  "description": "Spec-Driven Development + harness engineering toolkit for Claude Code, Codex, Cursor, and Gemini CLI. Installs a workflow MCP server in one npx command.",
  "keywords": [
    "spec-driven-development",
    "sdd",
    "mcp",
    "claude",
    "claude-code",
    "codex",
    "cursor",
    "gemini",
    "ai-coding",
    "harness-engineering",
    "code-review",
    "agent-tooling"
  ],
  "license": "MIT",
  "author": "hir4ta",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hir4ta/qult.git"
  },
  "homepage": "https://github.com/hir4ta/qult",
  "bugs": {
    "url": "https://github.com/hir4ta/qult/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "qult": "dist/cli.js"
  },
  "exports": {
    ".": "./dist/cli.js",
    "./mcp": "./dist/mcp-server.js"
  },
  "files": [
    "dist/",
    "src/templates/bundled/"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run typecheck && npm run lint && npm test && npm run build"
  },
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/node": "^20",
    "tsup": "^8",
    "typescript": "^5.8",
    "vitest": "^3"
  }
}
